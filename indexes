<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MIEAI - National Intelligence</title>
    <!-- Import Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;400;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #000000;
            --text-color: #FFFFFF;
            
            /* ==========================================
               NOTA: TEMPAT KECIK OR BESARKAN LOGO KAU 
               Ubah nilai px kat bawah ni (Contoh: 400px)
               ========================================== */
            --logo-size: 600px; 
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow: hidden; /* Elak scrollbar muncul masa morphing */
            height: 100vh;
            width: 100vw;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        /* Effect Bintang Halus */
        .stars-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at top, #0a0a0a 0%, #000000 100%);
            z-index: -1;
        }

        .star {
            position: absolute;
            background: white;
            border-radius: 50%;
            opacity: 0;
            animation: twinkle var(--duration) infinite ease-in-out;
        }

        @keyframes twinkle {
            0%, 100% { opacity: 0; transform: scale(0.5); }
            50% { opacity: 0.7; transform: scale(1.2); }
        }

        /* Logo Section */
        .logo-container {
            margin-bottom: 60px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .main-logo {
            width: var(--logo-size);
            height: auto;
            display: block;
            /* Filter ni nak bagi logo nampak blend sikit dengan dark mode */
            filter: drop-shadow(0 0 20px rgba(255,255,255,0.05));
            transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .main-logo:hover {
            transform: scale(1.02);
        }

        /* Product Section */
        .product-line {
            display: flex;
            gap: 60px;
            justify-content: center;
            align-items: flex-start; /* Aling top supaya text expand ke bawah */
            width: 100%;
            max-width: 1400px;
            padding: 0 40px;
        }

        .product-item {
            position: relative;
            cursor: pointer;
            text-align: center;
            flex: 1; /* Agihkan ruang sama rata */
            max-width: 350px;
        }

        .product-name {
            font-size: 1.1rem;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            white-space: nowrap;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(255,255,255,0); /* Hidden line */
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .product-detail {
            max-height: 0;
            opacity: 0;
            overflow: hidden;
            font-size: 0.85rem;
            font-weight: 200;
            color: #999999;
            margin-top: 0;
            line-height: 1.8;
            transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            text-align: center;
        }

        /* Morphing Effect on Hover */
        .product-item:hover .product-name {
            color: #ffffff;
            letter-spacing: 0.3em;
            border-bottom: 1px solid rgba(255,255,255,0.2);
        }

        .product-item:hover .product-detail {
            max-height: 200px; /* Bagi cukup ruang untuk text */
            opacity: 1;
            margin-top: 20px;
        }

        /* Mobile Optimization */
        @media (max-width: 900px) {
            body {
                overflow-y: auto;
                padding: 40px 0;
            }
            .product-line {
                flex-direction: column;
                align-items: center;
                gap: 40px;
            }
            :root {
                --logo-size: 80vw;
            }
            .product-detail {
                max-width: 280px;
            }
        }
    </style>
</head>
<body>

    <!-- Latar belakang bintang bintik -->
    <div class="stars-container" id="stars"></div>

    <div class="logo-container">
        <!-- ==========================================
             NOTA: PASTE URL GAMBAR/LOGO KAU KAT BAWAH NI 
             ========================================== -->
        <img src="PASTE_URL_GAMBAR_KAU" alt="MIEAI LOGO" class="main-logo">
    </div>

    <div class="product-line">
        <!-- Produk 1 -->
        <div class="product-item">
            <div class="product-name">National Brain</div>
            <div class="product-detail">
                12-Synapse Neural Architecture: Unifying global intelligence to architect a superior socioeconomic and educational powerhouse for a new era.
            </div>
        </div>

        <!-- Produk 2 -->
        <div class="product-item">
            <div class="product-name">EduHub</div>
            <div class="product-detail">
                The Nexus of Discovery: Empowering researchers and students with high-speed project acceleration, collaborative synthesis, and academic excellence.
            </div>
        </div>

        <!-- Produk 3 -->
        <div class="product-item">
            <div class="product-name">Statistics Tool</div>
            <div class="product-detail">
                Precision Analytics: Advanced Python-driven suite for high-fidelity data simulation, predictive modeling, and multidimensional structural analysis.
            </div>
        </div>
    </div>

    <script>
        // Script untuk generate bintik bintang secara random
        const starsContainer = document.getElementById('stars');
        const starCount = 150; // Tambah sikit lagi bintang biar nampak mewah

        for (let i = 0; i < starCount; i++) {
            const star = document.createElement('div');
            star.className = 'star';
            const size = (Math.random() * 1.5 + 0.5) + 'px';
            star.style.width = size;
            star.style.height = size;
            
            // Fokuskan bintang di bahagian atas 70% skrin
            star.style.top = Math.random() * 70 + '%';
            star.style.left = Math.random() * 100 + '%';
            
            // Random duration untuk kelipan
            star.style.setProperty('--duration', Math.random() * 3 + 3 + 's');
            // Delay random supaya tak berkelip serentak
            star.style.animationDelay = Math.random() * 5 + 's';
            
            starsContainer.appendChild(star);
        }
    </script>
</body>
</html>

